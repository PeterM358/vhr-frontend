# =============================================================================
# Veversal frontend — LOCAL development
# Copy to .env.local (never commit secrets)
# =============================================================================

# Django API (host machine or Docker-published port)
EXPO_PUBLIC_API_BASE_URL=http://localhost:8000

# WebSocket — same host as API when using Daphne; override if needed
EXPO_PUBLIC_WS_BASE_URL=ws://localhost:8000

# Physical device on Wi‑Fi (native only; ignored when API URL is set above)
# EXPO_PUBLIC_DEV_LAN_HOST=192.168.0.105

# Google OAuth (optional for local web login)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Google Analytics 4 — keep false for local dev (docs/analytics.md)
VITE_ENABLE_ANALYTICS=false
VITE_GA_MEASUREMENT_ID=G-MP75X85E34
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=
