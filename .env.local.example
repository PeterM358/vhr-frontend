# =============================================================================
# Veversal frontend — LOCAL development
# Copy to .env.local (never commit secrets)
# =============================================================================

# Django API — omit on native simulators to auto-pick platform host:
#   iOS simulator → 127.0.0.1, Android emulator → 10.0.2.2, physical device → LAN host below.
# Web dev may set localhost explicitly:
# EXPO_PUBLIC_API_BASE_URL=http://localhost:8000
#
# Dev API port (used when EXPO_PUBLIC_API_BASE_URL is unset). MUST match Daphne's -p flag.
# Django runserver defaults to 8000; Daphne is often 8001 — mismatch causes WS close_code 1006.
EXPO_PUBLIC_DEV_API_PORT=8001

# WebSocket — off by default with Django runserver (HTTP only). Enable when running Daphne:
EXPO_PUBLIC_WS_ENABLED=true
# WS URL defaults from API (http→ws). Override only if WS is on a different host/port:
# EXPO_PUBLIC_WS_BASE_URL=ws://127.0.0.1:8001

# Physical device on Wi‑Fi (native only; used when API URL is unset)
# EXPO_PUBLIC_DEV_LAN_HOST=192.168.0.105

# Google OAuth (optional for local web login)
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=

# Google Analytics 4 — keep false for local dev (docs/analytics.md)
VITE_ENABLE_ANALYTICS=false
VITE_GA_MEASUREMENT_ID=G-MP75X85E34

# Veversal internal search analytics — keep false until backend endpoint is live
VITE_ENABLE_INTERNAL_ANALYTICS=false
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=
