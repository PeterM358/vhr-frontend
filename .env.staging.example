# =============================================================================
# Veversal frontend — STAGING / BETA web build
# Copy to .env.staging on the build machine (never commit secrets)
# Web app: https://beta.veversal.com
# API:      https://api-beta.veversal.com
# =============================================================================

EXPO_PUBLIC_API_BASE_URL=https://api-beta.veversal.com
EXPO_PUBLIC_WS_BASE_URL=wss://api-beta.veversal.com

# OAuth — use Web client ID for beta.veversal.com authorized origins
EXPO_PUBLIC_GOOGLE_CLIENT_ID=
EXPO_PUBLIC_GOOGLE_ANDROID_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_MAPS_API_KEY=
